#show: kodama

#set text(font: ("Inria Sans", "HarmonyOS Sans SC"))

#metadata((
  title: "The Celtic Myths 摘录", //
  date: "February 21, 2025",
  author: local("/kokic", text: "kokic"),
  taxon: "peruse", 
  douban: external("https://book.douban.com/subject/31093378", "豆瓣"),
